{
  "manifest_version": 3,
  "name": "Neon Tic Tac Toe",
  "description": "Dark neon Tic Tac Toe extension popup with Easy, Medium, and Hard AI.",
  "version": "1.0.0",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Neon Tic Tac Toe",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}